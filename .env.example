# .env.example — DockerRescueKit environment variables
#
# Copy this file to .env and fill in the values you want to override.
# Every variable listed here has a built-in default, so you only need
# to set the ones that matter for your deployment.
#
# For Docker / homelab use, set DRK_API_KEY and DRK_ENCRYPTION_KEY once
# and store them securely (e.g. a password manager or Vault).
#
# WARNING: Never commit a populated .env file to source control.

# ── Data persistence ──────────────────────────────────────────────────────────

# Directory where the SQLite database, secrets.json, and staging area live.
# Default: "data"  (relative to the working directory)
# Docker default: /data  (bind-mounted named volume drk-data)
DRK_DATA_DIR=data

# ── Security ──────────────────────────────────────────────────────────────────

# Override the API key that every /api/* request must present in the
# x-api-key header (or ?apiKey= query param).
# If unset, the backend generates a random 32-char key on first start and
# persists it in $DRK_DATA_DIR/secrets.json.
# Tip: generate with: openssl rand -hex 24
DRK_API_KEY=

# Override the AES encryption key used to encrypt connector credentials
# and other secrets at rest.
# Set this ONCE and NEVER change it — changing it will permanently break
# decryption of all stored secrets.
# If unset, the backend generates and persists one automatically.
# Tip: generate with: openssl rand -hex 32
DRK_ENCRYPTION_KEY=

# ── UI ────────────────────────────────────────────────────────────────────────

# Absolute path to the directory containing the built frontend (index.html).
# The backend searches several relative locations automatically, so this is
# only needed when the UI is served from a non-standard path.
# Default: auto-detected (packages/backend/public in production Docker image)
DRK_UI_DIR=

# ── HTTP server ───────────────────────────────────────────────────────────────

# TCP port the Express server listens on.
# Default: 42880
PORT=42880

# Node environment.  Affects logging verbosity and a few runtime behaviours.
# Values: development | production
# Default: development
NODE_ENV=development

# ── External tool paths ───────────────────────────────────────────────────────

# Absolute path to the restic binary, if it is not already on the system PATH.
# Leave blank to use whichever "restic" is found in PATH.
# Example (Windows): RESTIC_BIN=C:\tools\restic.exe
RESTIC_BIN=

# Path to the rclone configuration file, if it is not in the default location
# (~/.config/rclone/rclone.conf on Linux/macOS,
#  %APPDATA%\rclone\rclone.conf on Windows).
# Leave blank to use the default.
RCLONE_CONFIG=
